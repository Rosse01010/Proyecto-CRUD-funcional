{
    "name": "voyage-passtransport-root",
    "version": "1.0.0",
    "description": "Root package.json to easily run both the .NET API and Angular UI simultaneously.",
    "scripts": {
        "install:all": "cd smart-journey-ui && npm install",
        "dev:api": "cd SmartJourney.API && dotnet run",
        "dev:ui": "cd smart-journey-ui && npm run start",
        "dev": "concurrently \"npm run dev:api\" \"npm run dev:ui\"",
        "start": "npm run dev",
        "postinstall": "npm run install:all"
    },
    "devDependencies": {
        "concurrently": "^8.2.2"
    }
}